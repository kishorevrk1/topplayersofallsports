spring:
  datasource:
    url: jdbc:postgresql://localhost:5433/highlights_db
    username: postgres
    password: postgres
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2
  
  data:
    redis:
      host: localhost
      port: 6379
  
  jpa:
    show-sql: true

# Temporal configuration for local development
temporal:
  connection:
    target: 127.0.0.1:7233
  namespace: default
  worker:
    task-queue: highlights-ingest

# YouTube API configuration (local development)
youtube:
  api-key: ${YOUTUBE_API_KEY:your-api-key-here}

logging:
  level:
    root: INFO
    com.topplayersofallsports.highlights: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE
