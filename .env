# Google Sign-In credentials for Firebase
VITE_GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID_REMOVED
VITE_GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET_REMOVED
# REPLACE THE VALUES BELOW WITH YOUR ACTUAL KEYS IF NOT AUTOMATICALLY SET

VITE_SUPABASE_URL=https://dummy.supabase.co
VITE_SUPABASE_ANON_KEY=dummykey.updateyourkkey.here
VITE_OPENAI_API_KEY=OPENAI_API_KEY_REMOVED
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here
VITE_ADSENSE_ID=your-adsense-id-here
VITE_PERPLEXITY_API_KEY=your-perplexity-api-key-here
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# Backend API URL
VITE_API_URL=http://localhost:8080

# Highlights Service API (IMPORTANT: No trailing slash!)
VITE_HIGHLIGHTS_API_URL=http://localhost:8081/api/highlights
VITE_ENABLE_DEBUG_LOGGING=true

# Calendar Service API (IMPORTANT: No trailing slash!)
VITE_CALENDAR_API_URL=http://localhost:8083/api/calendar

# Player Service API (IMPORTANT: No trailing slash!)
VITE_PLAYER_API_URL=http://localhost:8084

# API-Sports.io Key (using backend proxy is recommended)
VITE_API_SPORTS_KEY=APISPORTS_KEY_REMOVED

# Development Configuration
VITE_ENV=development
VITE_DEBUG=true
