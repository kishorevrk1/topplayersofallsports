# Environment Configuration for TopPlayersofAllSports Frontend

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_ENVIRONMENT=development

# Highlights Service API (New)
# IMPORTANT: Do NOT add trailing slash to the URL
VITE_HIGHLIGHTS_API_URL=http://localhost:8081/api/highlights
VITE_ENABLE_DEBUG_LOGGING=true

# OAuth Configuration
REACT_APP_GOOGLE_CLIENT_ID=882439388803-8qdpntj38midjvlmcprku4b82lp125j3.apps.googleusercontent.com

# Security Configuration
REACT_APP_TOKEN_REFRESH_THRESHOLD=300000
REACT_APP_SESSION_TIMEOUT=3600000

# Feature Flags
REACT_APP_ENABLE_OAUTH=true
REACT_APP_ENABLE_REMEMBER_ME=true
REACT_APP_ENABLE_DEBUG_LOGGING=true

# CDN and Asset Configuration
REACT_APP_ASSET_BASE_URL=
REACT_APP_ENABLE_PWA=false

